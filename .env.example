SECRET_KEY=replace-this-secret
DATABASE_URL=postgresql://db_user:db_password@localhost:5432/amazon_ads_analytics
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000
UPLOAD_FOLDER=uploads
